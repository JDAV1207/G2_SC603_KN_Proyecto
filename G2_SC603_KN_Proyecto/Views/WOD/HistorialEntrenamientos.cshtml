@model IEnumerable<G2_SC603_KN_Proyecto.Models.ViewModels.Wod.WodHistorialItemViewModel>
@{
    Layout = "_Layout";
    string rolActual = Context.Session.GetString("Rol") ?? string.Empty;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast show" style="background:#201f1f; color:#4ade80;">
        <span class="material-symbols-outlined">check_circle</span>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="toast show" style="background:#201f1f; color:#ffb4ab;">
        <span class="material-symbols-outlined">error</span>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div id="page-wod-historial" class="section-page active p-6 lg:p-8">

    <div class="flex items-center gap-3 mb-8">
        <a asp-controller="WOD" asp-action="MostrarWOD" class="btn-icon">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">Historial de Entrenamientos</h2>
            <p class="text-on-surface-variant text-xs mt-1">RMGM-WOD-003</p>
        </div>
    </div>

    <div class="bg-surface-container rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Entrenamiento</th>
                        <th>Objetivo</th>
                        <th>Coach</th>
                        @if (rolActual == "ADMIN" || rolActual == "TRAINER")
                        {
                            <th>Cliente</th>
                        }
                        <th>Ejercicios</th>
                        <th>Fecha</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td>@(string.IsNullOrEmpty(item.Objetivo) ? "—" : item.Objetivo)</td>
                                <td>@item.NombreEntrenador</td>
                                @if (rolActual == "ADMIN" || rolActual == "TRAINER")
                                {
                                    <td>@(item.NombreCliente ?? "—")</td>
                                }
                                <td>@item.CantidadEjercicios</td>
                                <td>@(item.Fecha?.ToString("dd/MM/yyyy") ?? "Sin asignar")</td>
                                <td>
                                    <a asp-controller="WOD" asp-action="DetalleEntrenamiento"
                                       asp-route-id="@item.IdRutina" class="btn-icon" title="Ver detalle">
                                        <span class="material-symbols-outlined text-[18px]">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-on-surface-variant py-6">
                                No existen entrenamientos registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
